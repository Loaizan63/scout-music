# ── Dependencias y código fuente ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build output (se regenera dentro del contenedor) ──────────────────────────
.next/
out/

# ── Caché pesada de Turbopack / webpack ───────────────────────────────────────
# ¡Este era el culpable de los 160 MB+ de contexto!
.next/cache/
.sst/
**/.turbo/

# ── Secretos — NUNCA deben entrar a la imagen ─────────────────────────────────
.env
.env.local
.env*.local
.env.production
.env.staging

# ── Git y herramientas de desarrollo ──────────────────────────────────────────
.git/
.gitignore
.gitattributes
.vscode/
.idea/
*.suo
*.sw?

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Documentación / CI (Docker no la necesita) ───────────────────────────────
README.md
*.md
.github/
php/